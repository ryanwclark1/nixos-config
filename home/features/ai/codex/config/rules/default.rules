# Codex Rules Configuration
# Rules control which commands Codex can run outside the sandbox
# See: https://developers.openai.com/codex/rules
# Syntax: Starlark (Python-like but safe)

# Git Operations - Read-only commands (safe)
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "branch", "tag", "remote", "blame", "grep", "describe"]],
    decision = "allow",
    justification = "Read-only git commands are safe",
    match = [
        "git status",
        "git diff",
        "git log --oneline",
        "git show HEAD",
        "git branch -a",
        "git remote -v",
        "git blame file.txt",
        "git grep pattern",
    ],
)

# Git Operations - Network operations (require approval)
prefix_rule(
    pattern = ["git", ["pull", "fetch", "clone"]],
    decision = "prompt",
    justification = "Network operations require approval",
    match = [
        "git pull origin main",
        "git fetch --all",
        "git clone https://github.com/user/repo.git",
    ],
)

# Git Operations - Force push (blocked)
prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force push is destructive and can overwrite remote history. Never allow force push.",
    match = [
        "git push --force",
        "git push --force origin main",
        "git push -f",
        "git push origin main --force",
    ],
)

# Git Operations - Regular push (require approval)
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing commits requires approval to prevent accidental pushes",
    match = [
        "git push origin main",
        "git push",
    ],
)

# Git Operations - Write operations (require approval)
prefix_rule(
    pattern = ["git", ["add", "commit", "stash", "merge", "tag"]],
    decision = "prompt",
    justification = "Git write operations require approval",
    match = [
        "git add file.txt",
        "git commit -m 'message'",
        "git stash",
        "git merge branch",
        "git tag v1.0",
    ],
)

# Git Operations - Highly destructive operations (blocked)
prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard reset is destructive and permanently loses uncommitted changes. Never allow hard reset.",
    match = [
        "git reset --hard HEAD~1",
        "git reset --hard origin/main",
        "git reset --hard",
    ],
)

# Git Operations - Clean untracked files (blocked)
prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "forbidden",
    justification = "git clean -fd permanently removes untracked files. Too dangerous to allow.",
    match = [
        "git clean -fd",
        "git clean -f -d",
    ],
)

# Git Operations - Destructive operations (require approval)
prefix_rule(
    pattern = ["git", ["reset", "rebase", "cherry-pick", "revert"]],
    decision = "prompt",
    justification = "History-modifying operations require approval",
    match = [
        "git reset --soft HEAD~1",
        "git reset --mixed HEAD~1",
        "git rebase main",
        "git cherry-pick abc123",
        "git revert HEAD",
    ],
)

# GitHub CLI - Read operations (safe)
prefix_rule(
    pattern = ["gh", ["pr", "view"], "list"],
    decision = "allow",
    justification = "Viewing PRs and issues is safe",
    match = [
        "gh pr view 123",
        "gh pr list",
        "gh issue view 456",
    ],
)

# GitHub CLI - Write operations (require approval)
prefix_rule(
    pattern = ["gh", ["pr", "create", "close", "merge", "comment"]],
    decision = "prompt",
    justification = "Creating or modifying PRs requires approval",
    match = [
        "gh pr create --draft",
        "gh pr close 123",
        "gh pr merge 123",
        "gh pr comment 123 --body 'LGTM'",
    ],
)

# Dangerous file operations (blocked)
prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Use git clean or explicit file removal instead. Never use rm -rf without explicit approval.",
    match = [
        "rm -rf /tmp/test",
        "rm -rf node_modules",
        "rm -rf /",
    ],
    not_match = [
        "rm -f file.txt",  # Single file removal is different
    ],
)

# File system operations - Dangerous patterns (blocked)
prefix_rule(
    pattern = ["chmod", "777"],
    decision = "forbidden",
    justification = "Overly permissive file permissions are a security risk",
    match = [
        "chmod 777 file",
        "chmod -R 777 directory",
    ],
)

# File system operations - Format operations (blocked)
prefix_rule(
    pattern = ["mkfs", "format", "dd", "of="],
    decision = "forbidden",
    justification = "Disk formatting operations are destructive and must be done manually",
    match = [
        "mkfs.ext4 /dev/sda1",
        "dd if=/dev/zero of=/dev/sda",
    ],
)

# System-level operations (blocked)
prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "System-level operations are not allowed. Use appropriate user-level commands instead.",
    match = [
        "sudo apt update",
        "sudo systemctl restart service",
    ],
)

# bd - Directory navigation (safe)
prefix_rule(
    pattern = ["bd"],
    decision = "allow",
    justification = "bd is a read-only directory navigation tool that safely navigates to parent directories",
    match = [
        "bd src",
        "bd config",
        "bd home",
        "bd project",
    ],
)

# Read-only file operations (safe)
prefix_rule(
    pattern = ["ls", "cat", "head", "tail", "grep", "file", "stat", "tree", "pwd", "which", "type"],
    decision = "allow",
    justification = "Read-only file inspection commands are safe",
    match = [
        "ls -la",
        "cat file.txt",
        "head -n 20 file.txt",
        "tail -f log.txt",
        "grep pattern file",
        "file document.pdf",
        "stat file.txt",
        "tree -L 3",
        "pwd",
        "which command",
        "type command",
    ],
)

# Modern CLI replacements - Read operations (safe)
prefix_rule(
    pattern = ["rg", "fd", "bat", "eza", "procs", "dust", "duf", "delta"],
    decision = "allow",
    justification = "Modern read-only CLI tool replacements are safe",
    match = [
        "rg pattern",
        "fd filename",
        "bat file.txt",
        "eza -la",
        "procs",
        "dust",
        "duf",
        "git diff | delta",
    ],
)

# Directory navigation tools (safe)
prefix_rule(
    pattern = ["zoxide", "cd"],
    decision = "allow",
    justification = "Directory navigation tools are read-only and safe",
    match = [
        "zoxide query project",
        "z project",
        "cd /path/to/dir",
    ],
)

# System information commands (safe)
prefix_rule(
    pattern = ["uname", "whoami", "date", "uptime", "env", "echo"],
    decision = "allow",
    justification = "System information commands are read-only and safe",
    match = [
        "uname -a",
        "whoami",
        "date",
        "uptime",
        "env",
        "echo $VAR",
    ],
)

# Text processing - Read operations (safe)
prefix_rule(
    pattern = ["jq"],
    decision = "allow",
    justification = "JSON processing read operations are safe",
    match = [
        "jq . file.json",
        "jq '.key' file.json",
    ],
)

prefix_rule(
    pattern = ["awk"],
    decision = "allow",
    justification = "AWK read operations are safe",
    match = [
        "awk '{print $1}' file.txt",
        "awk '/pattern/ {print}' file.txt",
    ],
)

# sed - Read operations (safe), write operations require approval
prefix_rule(
    pattern = ["sed", "-n"],
    decision = "allow",
    justification = "sed read operations (with -n flag) are safe",
    match = [
        "sed -n '1,10p' file.txt",
        "sed -n '/pattern/p' file.txt",
    ],
)

prefix_rule(
    pattern = ["sed", "-i"],
    decision = "prompt",
    justification = "sed in-place editing modifies files and requires approval",
    match = [
        "sed -i 's/old/new/g' file.txt",
        "sed -i.bak 's/old/new/' file.txt",
    ],
)

# Make - Build operations (require approval)
prefix_rule(
    pattern = ["make"],
    decision = "prompt",
    justification = "Build operations require approval",
    match = [
        "make",
        "make build",
        "make install",
        "make clean",
    ],
)

# Additional package managers (require approval)
prefix_rule(
    pattern = ["yarn", "pnpm", "bun"],
    decision = "prompt",
    justification = "Package installation/modification requires approval",
    match = [
        "yarn install",
        "yarn add package",
        "pnpm install",
        "pnpm add package",
        "bun install",
        "bun add package",
    ],
)

# Process management - Dangerous operations (blocked)
prefix_rule(
    pattern = ["kill", "-9"],
    decision = "forbidden",
    justification = "Process termination is dangerous and must be done manually",
    match = [
        "kill -9 1234",
        "killall -9 process",
    ],
)

# Helm - Kubernetes package manager (require approval)
prefix_rule(
    pattern = ["helm"],
    decision = "prompt",
    justification = "Kubernetes package operations require approval",
    match = [
        "helm install release chart",
        "helm upgrade release chart",
        "helm uninstall release",
    ],
)

# Docker operations - Read operations (safe)
prefix_rule(
    pattern = ["docker", ["ps", "images", "logs", "inspect", "exec"]],
    decision = "allow",
    justification = "Read-only Docker operations are safe",
    match = [
        "docker ps",
        "docker images",
        "docker logs container",
        "docker inspect image",
    ],
)

# Docker operations - Write operations (require approval)
prefix_rule(
    pattern = ["docker", ["run", "build", "push", "pull", "rm", "stop", "start", "compose"]],
    decision = "prompt",
    justification = "Docker operations that modify state require approval",
    match = [
        "docker run -it image",
        "docker build -t tag .",
        "docker push image",
        "docker rm container",
        "docker compose up",
    ],
)

# Kubernetes operations - Read operations (safe)
prefix_rule(
    pattern = ["kubectl", ["get", "describe", "logs", "top", "version"]],
    decision = "allow",
    justification = "Read-only Kubernetes operations are safe",
    match = [
        "kubectl get pods",
        "kubectl describe pod name",
        "kubectl logs pod",
    ],
)

# Kubernetes operations - Write operations (require approval)
prefix_rule(
    pattern = ["kubectl", ["apply", "delete", "create", "patch", "scale"]],
    decision = "prompt",
    justification = "Kubernetes write operations require approval",
    match = [
        "kubectl apply -f file.yaml",
        "kubectl delete pod name",
        "kubectl create deployment",
    ],
)

# Terraform operations (require approval)
prefix_rule(
    pattern = ["terraform", ["apply", "destroy", "plan"]],
    decision = "prompt",
    justification = "Infrastructure changes require approval",
    match = [
        "terraform apply",
        "terraform destroy",
        "terraform plan",
    ],
)

# SOPS operations (require approval)
prefix_rule(
    pattern = ["sops"],
    decision = "prompt",
    justification = "Secret management operations require approval",
    match = [
        "sops -e file.yaml",
        "sops -d file.encrypted",
        "sops updatekeys file.yaml",
    ],
)

# Network operations - Curl (allowed)
prefix_rule(
    pattern = ["curl"],
    decision = "allow",
    justification = "curl is a common development tool for API testing and data fetching",
    match = [
        "curl https://api.example.com/data",
        "curl -X POST https://api.example.com/endpoint",
        "curl -O https://example.com/file",
        "curl -L https://example.com/redirect",
    ],
)

prefix_rule(
    pattern = ["wget"],
    decision = "prompt",
    justification = "Network requests require approval",
    match = [
        "wget https://example.com/file",
    ],
)

# Package manager operations (require approval)
prefix_rule(
    pattern = ["npm", ["install", "uninstall", "publish"]],
    decision = "prompt",
    justification = "Package installation/modification requires approval",
    match = [
        "npm install package",
        "npm uninstall package",
        "npm publish",
    ],
)

prefix_rule(
    pattern = ["pip", ["install", "uninstall"]],
    decision = "prompt",
    justification = "Python package installation requires approval",
    match = [
        "pip install package",
        "pip uninstall package",
    ],
)

# Cargo operations (require approval)
prefix_rule(
    pattern = ["cargo", ["install", "update", "publish"]],
    decision = "prompt",
    justification = "Rust package operations require approval",
    match = [
        "cargo install tool",
        "cargo update",
        "cargo publish",
    ],
)

# Go operations (require approval)
prefix_rule(
    pattern = ["go", ["install", "get", "mod"]],
    decision = "prompt",
    justification = "Go package operations require approval",
    match = [
        "go install package@latest",
        "go get package",
        "go mod tidy",
    ],
)

# Nix operations - Read operations (safe)
prefix_rule(
    pattern = ["nix", ["eval", "search", "show", "path-info"]],
    decision = "allow",
    justification = "Read-only Nix operations are safe",
    match = [
        "nix eval nixpkgs#hello",
        "nix search nixpkgs python",
        "nix show-derivation path",
    ],
)

# nix-shell - Development environment (safe)
prefix_rule(
    pattern = ["nix-shell"],
    decision = "allow",
    justification = "nix-shell is a safe development environment tool that sets up a shell with dependencies",
    match = [
        "nix-shell",
        "nix-shell default.nix",
        "nix-shell shell.nix",
        "nix-shell -p python3",
        "nix-shell --run 'command'",
    ],
)

# Nix operations - Build operations (require approval)
prefix_rule(
    pattern = ["nix", ["build", "shell", "develop", "run"]],
    decision = "prompt",
    justification = "Nix build operations require approval",
    match = [
        "nix build .#package",
        "nix shell nixpkgs#python",
        "nix develop",
    ],
)

# Nix Flake operations (require approval)
prefix_rule(
    pattern = ["nix", "flake"],
    decision = "prompt",
    justification = "Flake operations modify the development environment",
    match = [
        "nix flake update",
        "nix flake lock",
        "nix flake check",
    ],
)

# Home Manager operations (blocked)
prefix_rule(
    pattern = ["home-manager"],
    decision = "prompt",
    justification = "Home Manager rebuilds must be done manually with explicit approval",
    match = [
        "home-manager switch",
        "home-manager switch --flake",
        "home-manager build",
    ],
)

# NixOS system operations (blocked)
prefix_rule(
    pattern = ["nixos-rebuild"],
    decision = "forbidden",
    justification = "System rebuilds must be done manually with explicit approval",
    match = [
        "nixos-rebuild switch",
        "nixos-rebuild boot",
        "nixos-rebuild test",
    ],
)

# Nix store operations (require approval)
prefix_rule(
    pattern = ["nix", ["store", "gc", "optimise"]],
    decision = "prompt",
    justification = "Store operations can free disk space but require approval",
    match = [
        "nix store gc",
        "nix store optimise",
    ],
)


