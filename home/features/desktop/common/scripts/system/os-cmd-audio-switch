#!/usr/bin/env bash

set -euo pipefail

focused_monitor=$(hyprctl monitors -j 2>/dev/null | jq -r '.[] | select(.focused == true).name' | head -1 || echo "")

if [[ -z "$focused_monitor" ]]; then
  echo "Error: Could not determine focused monitor" >&2
  exit 1
fi

sinks=$(pactl -f json list sinks 2>/dev/null | jq '[.[] | select((.ports | length == 0) or ([.ports[]? | .availability != "not available"] | any))]' || echo "[]")
sinks_count=$(echo "$sinks" | jq '. | length' || echo "0")

if [[ "$sinks_count" -eq 0 ]] || [[ "$sinks_count" == "null" ]]; then
  notify-send -t 2000 -u normal "Audio" "No audio devices found" || true
  exit 1
fi

current_sink_name=$(pactl get-default-sink 2>/dev/null || echo "")
current_sink_index=$(echo "$sinks" | jq -r --arg name "$current_sink_name" 'map(.name) | index($name) // "null"')

if [[ "$current_sink_index" != "null" ]] && [[ "$current_sink_index" =~ ^[0-9]+$ ]]; then
  next_sink_index=$(((current_sink_index + 1) % sinks_count))
else
  next_sink_index=0
fi

next_sink=$(echo "$sinks" | jq -r ".[$next_sink_index]")
next_sink_name=$(echo "$next_sink" | jq -r '.name')

if [[ -z "$next_sink_name" ]] || [[ "$next_sink_name" == "null" ]]; then
  echo "Error: Could not determine next sink" >&2
  exit 1
fi

next_sink_description=$(echo "$next_sink" | jq -r '.description // "null"')
if [[ "$next_sink_description" == "null" ]] || [[ -z "$next_sink_description" ]]; then
  sink_id=$(echo "$next_sink" | jq -r '.properties."object.id" // ""')
  if [[ -n "$sink_id" ]]; then
    next_sink_description=$(wpctl status 2>/dev/null | grep -E "\s+\*?\s+${sink_id}\." | sed -E 's/^.*[0-9]+\.\s+//' | sed -E 's/\s+\[.*$//' || echo "Audio Device")
  else
    next_sink_description="Audio Device"
  fi
fi

next_sink_volume=$(echo "$next_sink" | jq -r '.volume | to_entries[0].value.value_percent | sub("%"; "") // "0"' || echo "0")
next_sink_is_muted=$(echo "$next_sink" | jq -r '.mute // "false"')

if [[ "$next_sink_is_muted" == "true" ]] || [[ "${next_sink_volume:-0}" -eq 0 ]]; then
  icon_state="muted"
elif [[ "${next_sink_volume:-0}" -le 33 ]]; then
  icon_state="low"
elif [[ "${next_sink_volume:-0}" -le 66 ]]; then
  icon_state="medium"
else
  icon_state="high"
fi

next_sink_volume_icon="sink-volume-${icon_state}-symbolic"

if [[ "$next_sink_name" != "$current_sink_name" ]]; then
  pactl set-default-sink "$next_sink_name" || {
    echo "Error: Failed to set default sink" >&2
    exit 1
  }
fi

notify-send -t 2000 -u normal "Audio Output" "$next_sink_description" || true
