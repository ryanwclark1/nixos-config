{
  "id": "quickshell.ssh.monitor",
  "name": "SSH Monitor",
  "description": "First-party SSH launcher and bar plugin with manual hosts plus ssh-config import.",
  "author": "Quickshell",
  "version": "1.0.0",
  "type": "multi",
  "permissions": ["settings_read", "settings_write", "state_read", "state_write", "process"],
  "metadata": {
    "stateVersion": 1
  },
  "launcher": {
    "trigger": "!ssh",
    "noTrigger": true
  },
  "entryPoints": {
    "barWidget": "BarWidget.qml",
    "launcherProvider": "LauncherProvider.qml",
    "settings": "Settings.qml"
  }
}
