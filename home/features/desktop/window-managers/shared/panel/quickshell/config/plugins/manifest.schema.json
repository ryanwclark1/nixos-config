{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/quickshell/plugins/manifest.schema.json",
  "title": "Shared Panel Plugin Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "author",
    "version",
    "type",
    "permissions",
    "entryPoints"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["bar-widget", "desktop-widget", "launcher-provider", "daemon", "multi"]
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["settings_read", "settings_write", "state_read", "state_write", "process"]
      }
    },
    "launcher": {
      "type": "object",
      "properties": {
        "trigger": { "type": "string" },
        "noTrigger": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "entryPoints": {
      "type": "object",
      "properties": {
        "barWidget": { "type": "string", "pattern": "^(?!.*\\.\\.).*\\.qml$" },
        "desktopWidget": { "type": "string", "pattern": "^(?!.*\\.\\.).*\\.qml$" },
        "launcherProvider": { "type": "string", "pattern": "^(?!.*\\.\\.).*\\.qml$" },
        "daemon": { "type": "string", "pattern": "^(?!.*\\.\\.).*\\.qml$" },
        "settings": { "type": "string", "pattern": "^(?!.*\\.\\.).*\\.qml$" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "bar-widget" } } },
      "then": { "properties": { "entryPoints": { "required": ["barWidget"] } } }
    },
    {
      "if": { "properties": { "type": { "const": "desktop-widget" } } },
      "then": { "properties": { "entryPoints": { "required": ["desktopWidget"] } } }
    },
    {
      "if": { "properties": { "type": { "const": "launcher-provider" } } },
      "then": { "properties": { "entryPoints": { "required": ["launcherProvider"] } } }
    },
    {
      "if": { "properties": { "type": { "const": "daemon" } } },
      "then": { "properties": { "entryPoints": { "required": ["daemon"] } } }
    },
    {
      "if": { "properties": { "type": { "const": "multi" } } },
      "then": {
        "anyOf": [
          { "properties": { "entryPoints": { "required": ["barWidget"] } } },
          { "properties": { "entryPoints": { "required": ["desktopWidget"] } } },
          { "properties": { "entryPoints": { "required": ["launcherProvider"] } } },
          { "properties": { "entryPoints": { "required": ["daemon"] } } }
        ]
      }
    }
  ],
  "additionalProperties": true
}
